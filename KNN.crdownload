   ],
   "source": [
    "import os\n",
    "import platform\n",
    "\n",
    "print(f\"Node Name: {platform.node()}\")\n",
    "print(f\"Operating System: {platform.platform()}\")\n",
    "\n",
    "try:\n",
    "    from sklearnex import patch_sklearn\n",
    "    print(\"Intel(R) Extension for Scikit-learn is installed!\")\n",
    "except:\n",
    "    print(\"Intel extension not found. Using standard Scikit-learn.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "0ebaeb5c-8603-40fd-a1f0-4d24252bb440",
   "metadata": {},
   "outputs": [],
   "source": [
    "from timeit import default_timer as timer\n",
    "from IPython.display import HTML\n",
    "from sklearn import metrics\n",
    "from sklearn.datasets import fetch_openml\n",
    "from sklearn.model_selection import train_test_split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "4718b501-2e28-4529-94f3-3ef4f9902ba9",
   "metadata": {},
   "outputs": [],
   "source": [
    "x, y = fetch_openml(name=\"mnist_784\", return_X_y=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d7663cbc-c6b0-45a2-aa3b-ec0513fc9a7b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "((56000, 784), (14000, 784), (56000,), (14000,))"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "x_train, x_test, y_train, y_test = train_test_split(x, y, test_size=0.2, random_state=72)\n",
    "x_train.shape, x_test.shape, y_train.shape, y_test.shape"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "b3420395-36cf-407e-983d-e0c61bcd0307",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "Intel(R) Extension for Scikit-learn* enabled (https://github.com/intel/scikit-learn-intelex)\n"
     ]
    }
   ],
   "source": [
    "from sklearnex import patch_sklearn\n",
    "\n",
    "patch_sklearn()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "fd76a0f9-1254-4e27-b84c-cd69a1f61ca1",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'Extension for Scikit-learn time: 1.55 s'"
      ]
     },
     "execution_count": 6,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "\n",
    "params = {\"n_neighbors\": 40, \"weights\": \"distance\", \"n_jobs\": -1}\n",
    "start = timer()\n",
    "knn = KNeighborsClassifier(**params).fit(x_train, y_train)\n",
    "predicted = knn.predict(x_test)\n",
    "time_opt = timer() - start\n",
    "f\"Extension for Scikit-learn time: {time_opt:.2f} s\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "d8c9fefb-7815-4f8c-8c23-77aa46179279",
