   ],
   "source": [
    "report = metrics.classification_report(y_test, predicted)\n",
    "print(f\"Classification report for Extension for Scikit-learn KNN:\\n{report}\\n\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
